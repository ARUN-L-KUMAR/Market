# Backend Environment Variables
# Copy this file to .env and fill in the values

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/market

# Authentication
JWT_SECRET=your_jwt_secret_here

# CORS
FRONTEND_URL=http://localhost:5173

# PayU Payment Gateway
PAYU_KEY=your_payu_key_here
PAYU_SALT=your_payu_salt_here
PAYU_BASE_URL=https://test.payu.in/_payment

# Email (SMTP) — optional, falls back to console logging
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=AK Market <noreply@akmarket.com>

# Cloudinary — optional, needed for image cleanup on product deletion
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
